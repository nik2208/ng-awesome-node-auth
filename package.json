{
  "name": "ng-awesome-node-auth-prj",
  "version": "1.8.4",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:lib": "ng build ng-awesome-node-auth",
    "build:ssr": "npm run build:lib && ng build",
    "serve:ssr": "node dist/ng-awesome-node-auth-prj/server/server.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "description": "Official monorepo for ng-awesome-node-auth library and it's Angular SSR demo dashboard",
  "private": true,
  "packageManager": "npm@11.6.4",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nik2208/ng-awesome-node-auth.git"
  },
  "keywords": [
    "auth",
    "angular",
    "awesome-node-auth",
    "authentication",
    "jwt",
    "admin-ui",
    "ssr"
  ],
  "author": "Nicola Brecciaroli",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nik2208/ng-awesome-node-auth/issues"
  },
  "homepage": "https://www.awesomenodeauth.com/",
  "dependencies": {
    "@angular/common": "^21.2.4",
    "@angular/compiler": "^21.2.4",
    "@angular/core": "^21.2.4",
    "@angular/forms": "^21.2.4",
    "@angular/platform-browser": "^21.2.4",
    "@angular/platform-server": "^21.2.4",
    "@angular/router": "^21.2.4",
    "@angular/ssr": "^21.2.2",
    "awesome-node-auth": "1.8.4",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.4",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "jsdom": "^27.1.0",
    "ng-packagr": "^21.2.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  },
  "overrides": {
    "undici": "^7.23.1"
  }
}